SLACK_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
SLACK_APP_TOKEN=YOUR_APP_TOKEN_HERE

# Optional: set these if you use a custom Claude-compatible proxy/backend.
ANTHROPIC_BASE_URL=YOUR_CLAUDE_BASE_URL_HERE
ANTHROPIC_AUTH_TOKEN=YOUR_CLAUDE_AUTH_TOKEN_HERE

# Optional: override the default Claude model used by run_claude.sh.
# Defaults to claude-sonnet-4-6 for faster replies.
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6

# Optional: allow longer Claude tasks before the bot reports a timeout.
CLAUDE_SLACK_TIMEOUT_SECONDS=1800
